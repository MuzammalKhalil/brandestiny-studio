            },
            {
              "type": "group",
              "id": "N2Whs",
              "x": 0,
              "y": 4735,
              "name": "Group 1160444825",
              "children": [
                {
                  "type": "frame",
                  "id": "zg1Ck",
                  "x": 0,
                  "y": 97,
                  "name": "Frame 44",
                  "clip": true,
                  "width": 1920,
                  "height": 562,
                  "stroke": {
                    "align": "inside",
                    "thickness": 1
                  },
                  "layout": "none",
                  "children": [
                    {
                      "type": "text",
                      "id": "2AH2q",
                      "x": 342,
                      "y": 0,
                      "name": "Established in 2014, Brandestiny was created with a simple purpose – to offer the kind of service our founders wished they had for their own ventures. Built on values that truly matter, we have grown by staying true to that ethos. Our independence allows us to carve our own path, free from corporate red tape or the need to follow trends dictated by big tech. Instead, we offer advice and strategies tailored specifically to your business, always focused on your goals. Being independent also means choosing the best team for your project. We collaborate with some of the industry’s finest specialists and, if something lies beyond our expertise, we will connect you with the right experts. At Brandestiny, people are at the heart of everything we do. Our team of digital specialists takes pride in delivering an experience worth talking about – and that is why so many of our new clients come through word of mouth.",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": 1236,
                      "content": "Established in 2014, Brandestiny was created with a simple\npurpose – to offer the kind of service our founders wished they had\nfor their own ventures. Built on values that truly matter, we have\ngrown by staying true to that ethos.\n\nOur independence allows us to carve our own path, free from corporate red tape or the need to follow trends dictated by big tech. Instead, we offer advice and strategies tailored specifically to\nyour business, always focused on your goals.\n\nBeing independent also means choosing the best team for your project. We collaborate with some of the industry’s finest specialists and, if something lies beyond our expertise, we will connect you\nwith the right experts.\n\nAt Brandestiny, people are at the heart of everything we do. Our\nteam of digital specialists takes pride in delivering an experience worth talking about – and that is why so many of our new clients come through word of mouth.",
                      "lineHeight": 1.6,
                      "fontFamily": "Helvetica Now Display",
                      "fontSize": 40,
                      "fontWeight": "500"
                    }
                  ]
                },
